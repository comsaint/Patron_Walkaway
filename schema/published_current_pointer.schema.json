{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://patron-walkaway.local/schema/published_current_pointer.schema.json",
  "title": "PublishedCurrentPointer",
  "description": "Small pointer file for active published snapshot (rollback = swap pointer).",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "active_published_snapshot_id",
    "active_published_snapshot_relpath",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "published_current_pointer_v1"
    },
    "active_published_snapshot_id": { "type": "string" },
    "active_published_snapshot_relpath": {
      "type": "string",
      "description": "Relative to repo data root, POSIX-style"
    },
    "previous_active_published_snapshot_id": { "type": ["string", "null"] },
    "updated_at": { "type": "string" }
  }
}
