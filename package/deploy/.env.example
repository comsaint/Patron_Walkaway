# =============================================================================
# Walkaway ML deploy — copy this file to ".env" (leading dot) next to main.py.
# Only CH_USER and CH_PASS are required for a minimal start; uncomment and set
# optional variables as needed. Full SSOT for env parsing: trainer/core/config.py
# =============================================================================

# ----- ClickHouse (required) -----
CH_USER=
CH_PASS=

# ----- ClickHouse (optional; defaults match trainer/core/config.py) -----
# CH_HOST=gdpedw
# CH_PORT=8123
# CH_SECURE=False
# SOURCE_DB=GDP_GMWDS_Raw
# CH_TEAMDB_HOST=GAD10DMTDBSP21

# ----- ML API -----
# PORT=8001
# ML_API_PORT=8001

# ----- Log verbosity (deploy process: scorer + validator + Flask) -----
# DEPLOY_LOG_LEVEL takes precedence over LOGLEVEL when both are set (see package/deploy/main.py).
# Typical: INFO (default), DEBUG for troubleshooting (payout-age cap, per-cycle scorer lines).
DEPLOY_LOG_LEVEL=INFO
# LOGLEVEL=INFO
# HTTP access: werkzeug is forced to WARNING in main.py (not configurable via env today).

# ----- Paths (optional; main.py sets defaults under this deploy folder if unset) -----
# STATE_DB_PATH=local_state/state.db
# MODEL_DIR=models
# PREDICTION_LOG_DB_PATH=local_state/prediction_log.db
# DATA_DIR is always set by main.py to "<deploy_root>/data" after .env load (profile + canonical artifacts).

# ----- Scorer windows (optional) -----
# Lookback for ClickHouse fetch and feature build (hours). Capped by SCORER_LOOKBACK_HOURS_MAX.
# SCORER_LOOKBACK_HOURS=8
# SCORER_LOOKBACK_HOURS_MAX=8760

# Only score / write prediction_log / emit alerts for new bets whose payout_complete_dtm is within
# the last N hours (HK semantics). Unset or blank = disabled (legacy behavior).
SCORER_COLD_START_WINDOW_HOURS=2

# If set (>0), ignore state DB runtime_rated_threshold older than this many hours (online calibration).
# RUNTIME_THRESHOLD_MAX_AGE_HOURS=

# Heavy CPU; default off. Set to 1/true/yes to enable SHAP reason codes on alerts.
# SCORER_ENABLE_SHAP_REASON_CODES=0

# ----- Prediction log housekeeping (optional; export / retention scripts on same host) -----
# PREDICTION_EXPORT_SAFETY_LAG_MINUTES=5
# PREDICTION_EXPORT_BATCH_ROWS=10000
# PREDICTION_LOG_RETENTION_DAYS=30
# PREDICTION_LOG_RETENTION_DELETE_BATCH=5000
# PREDICTION_LOG_SUMMARY_WINDOW_MINUTES=60

# ----- Training-only env vars (ignored by deploy API process; listed for parity / shared hosts) -----
# LIGHTGBM_DEVICE_TYPE=cpu
# LIGHTGBM_GPU_N_JOBS=4
