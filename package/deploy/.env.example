# Copy to .env and fill in. You only need to set CH_USER and CH_PASS below.

# ClickHouse (required for scorer and validator)
# Host, port, and database match trainer defaults; change if your setup differs.
CH_HOST=gdpedw
CH_PORT=8123
SOURCE_DB=GDP_GMWDS_Raw

# Required: set your ClickHouse username and password
CH_USER=
CH_PASS=

# Optional: TLS for ClickHouse
# CH_SECURE=False

# API server port (default 8001)
PORT=8001
# ML_API_PORT=8001

# Optional: override paths (default: deploy root / local_state, / models)
# Keep runtime DBs in the same local_state directory:
# STATE_DB_PATH=/path/to/local_state/state.db
# PREDICTION_LOG_DB_PATH=/path/to/local_state/prediction_log.db
# MODEL_DIR=/path/to/models
# DATA_DIR=/path/to/data
