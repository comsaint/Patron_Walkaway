# ClickHouse (required for trainer / scorer / validator when using ClickHouse)
CH_HOST=gdpedw
CH_TEAMDB_HOST=GAD10DMTDBSP21
CH_PORT=8123
CH_USER=
CH_PASS=
CH_SECURE=False
SOURCE_DB=GDP_GMWDS_Raw

# Optional: override default paths (defaults under repo out/ or local_state/)
# Keep runtime DBs in the same local_state directory to avoid path mismatch:
# STATE_DB_PATH=C:/path/to/repo/local_state/state.db
# PREDICTION_LOG_DB_PATH=C:/path/to/repo/local_state/prediction_log.db
# MODEL_DIR=C:/path/to/repo/out/models
# DATA_DIR=C:/path/to/repo/data

# Scorer polls: invalid or <=0 falls back to 8 (Phase 2); values above SCORER_LOOKBACK_HOURS_MAX are capped (default 8760h)
# SCORER_LOOKBACK_HOURS=8
# SCORER_LOOKBACK_HOURS_MAX=8760
# Ignore state DB runtime_rated_threshold older than this many hours (unset = no TTL)
# RUNTIME_THRESHOLD_MAX_AGE_HOURS=48
