# MLflow tracking server (Phase 2 P0–P1)
MLFLOW_TRACKING_URI=

# When the server is behind Identity-Aware Proxy (IAP), set this to the IAP OAuth 2.0
# client ID (…apps.googleusercontent.com), not the Cloud Run URL. Optional if no IAP.
# MLFLOW_IAP_AUDIENCE=123456789-abc.apps.googleusercontent.com

# Experiment namespaces (recommended on shared MLflow server)
# Use <project>/<environment>/<pipeline> naming to prevent cross-project mixing.
# Keep environment explicit (dev, staging, prod) for easier filtering and access control.
# Recommended production values:
#   MLFLOW_EXPERIMENT_TRAIN=patron_walkaway/prod/train
#   MLFLOW_EXPERIMENT_EXPORT=patron_walkaway/prod/prediction_export
# Recommended staging values:
#   MLFLOW_EXPERIMENT_TRAIN=patron_walkaway/staging/train
#   MLFLOW_EXPERIMENT_EXPORT=patron_walkaway/staging/prediction_export
# Recommended local development values:
#   MLFLOW_EXPERIMENT_TRAIN=patron_walkaway/dev-<user-or-machine>/train
#   MLFLOW_EXPERIMENT_EXPORT=patron_walkaway/dev-<user-or-machine>/prediction_export
MLFLOW_EXPERIMENT_TRAIN=patron_walkaway/dev-laptop/train
MLFLOW_EXPERIMENT_EXPORT=patron_walkaway/dev-laptop/prediction_export

# GCP service account key path for Cloud Run auth (optional)
# Use absolute path or path relative to repo root. Do not put this in .env.
GOOGLE_APPLICATION_CREDENTIALS=

# ---------------------------------------------------------------------------
# MLflow system metrics (CPU / RAM / …) — optional
# ---------------------------------------------------------------------------
# When set, MLflow records built-in system/* metrics on the active run (see MLflow docs).
# Requires psutil in the same process: pip install psutil
# (or: pip install walkaway_ml[mlflow-system-metrics] from pyproject optional deps).
# GPU metrics (optional): nvidia-ml-py or similar — only if you need GPU in MLflow UI.
#
# Applies to any code path that calls mlflow.start_run / safe_start_run with this env set,
# including training (run_pipeline) and prediction export (export_predictions_to_mlflow).
# To avoid system/* on export runs, do not set this in the export job env, or split env files.
# MLFLOW_ENABLE_SYSTEM_METRICS_LOGGING=true
#
# UI: open the run in MLflow → Metrics tab to inspect the recorded system/* time series
# (when logging succeeded and the process had psutil available).
